<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        App colours are defined in core/theme/Color.kt and managed entirely
        by MaterialTheme. The single XML colour below is needed by
        Theme.SplashScreen, which can't read Compose values.

        splash_background — matches LightColorScheme.background (Neutral98).
        The android:colorBackground in themes.xml provides the dark-mode
        counterpart, so users on a dark system don't get a flash of light
        before Compose paints.
    -->
    <color name="splash_background">#FFFAFAFA</color>
    <color name="splash_background_dark">#FF121212</color>

    <!-- Brand indigo violet (#6E60CF) — used as the splash icon tint and
         as a fallback accent in places that can't reference Compose
         colors (legacy widgets, RemoteViews). -->
    <color name="brand_primary">#FF6E60CF</color>
</resources>
