rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // ── Group rule helpers ────────────────────────────────────────────────
    // Pulled out so the per-field gating in /groups/{id} update stays
    // readable. Each helper takes the groupId path variable explicitly
    // so they can be reused under nested matches.

    /**
     * True when the requester has an ADMIN role in this group's
     * members subcollection. Used by every privileged group write.
     * Failsafe: treats a missing member doc as "not admin", so a
     * brand-new account can never accidentally short-circuit gating.
     */
    function isCurrentAdmin(gid) {
      return exists(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid)).data.role == 'ADMIN';
    }

    /**
     * True when this update only mutates the keys in `keys`. Used to
     * gate per-field write lanes (self-join, self-leave, meetup pin).
     */
    function onlyAffects(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    /**
     * True when the update is a single-user self-join: the requester
     * appears in afterIds but not in beforeIds, and only memberIds /
     * memberCount changed. Allows the join-by-code flow without
     * needing admin tools.
     */
    function isSelfJoinUpdate(gid) {
      return onlyAffects(['memberIds', 'memberCount'])
        && !(request.auth.uid in resource.data.memberIds)
        && (request.auth.uid in request.resource.data.memberIds);
    }

    /**
     * Mirror of [isSelfJoinUpdate] for the leave-group flow.
     */
    function isSelfLeaveUpdate(gid) {
      return onlyAffects(['memberIds', 'memberCount'])
        && (request.auth.uid in resource.data.memberIds)
        && !(request.auth.uid in request.resource.data.memberIds);
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSelf(userId);

      // ── Friends subcollection (denormalized summary) ──
      // Development: owner OR admin can write.
      // Switch to admin-only when Cloud Functions handle all friendship writes.
      match /friends/{friendUid} {
        allow read: if isSelf(userId);
        allow write: if isSelf(userId) || isAdmin();
      }

      // ── Inbox / Outbox aggregation docs ──
      match /inbox/{docId} {
        allow read: if isSelf(userId);
        allow write: if isSelf(userId) || isAdmin();
      }
      match /outbox/{docId} {
        allow read: if isSelf(userId);
        allow write: if isSelf(userId) || isAdmin();
      }

      // ── Social summary counter ──
      match /summary/{docId} {
        allow read: if isSelf(userId);
        allow write: if isSelf(userId) || isAdmin();
      }

      // ── Blocks (private to the blocker) ──
      match /blocks/{blockedUid} {
        allow read, write: if isSelf(userId);
      }

      // ── Preferences (private to the user) ──
      // Holds per-user app preferences that are too small for their own
      // collection — currently just the "close friends" set used by the
      // notification system to bypass quiet hours.
      //
      // Doc shape (closeFriends):
      //   { members: Map<friendUid, addedAtMillis> }
      //
      // Read + write are owner-only. No other user has any business
      // touching another user's preferences.
      match /preferences/{docId} {
        allow read, write: if isSelf(userId);
      }

      // ── Notifications inbox ──────────────────────────────────────────
      // SINGLE-DOC AGGREGATE PATTERN — mirrors the friend-requests inbox.
      // One document at `users/{uid}/inbox/notifications` holds the entire
      // notification map keyed by notification id. Costs 1 read per inbox
      // open instead of N reads (one per notification) — at 50–200
      // notifications/user the savings dominate.
      //
      // Document shape:
      //   {
      //     entries: { [id]: { type, title, body, timestamp, isRead, ... } },
      //     updatedAt: <epoch ms>
      //   }
      //
      // Cloud Functions / socket server are the only writers that *create*
      // entries; the client only flips `isRead` flags via dotted paths
      // and removes individual entries on delete. A daily Cloud Scheduler
      // job prunes entries older than 30 days from the map.
      //
      // Rule already covered by the broader `match /inbox/{docId}` rule
      // above — no separate rule needed since both notification and
      // friend-request inboxes share the same owner-only / admin-write
      // semantics.
      //
    }

    // ===== FRIENDSHIPS =====
    match /friendships/{friendshipId} {
      // Read: pair members (supports both new `members` array and legacy requesterId/receiverId)
      allow read: if isAuthenticated()
        && (request.auth.uid in resource.data.members
            || request.auth.uid == resource.data.requesterId
            || request.auth.uid == resource.data.receiverId);

      // Create: requester or admin
      allow create: if isAuthenticated()
        && (request.auth.uid == request.resource.data.requesterId || isAdmin());

      // Update: involved parties or admin
      allow update: if isAuthenticated()
        && (request.auth.uid in resource.data.members
            || request.auth.uid == resource.data.requesterId
            || request.auth.uid == resource.data.receiverId
            || isAdmin());

      // Delete: involved parties or admin
      allow delete: if isAuthenticated()
        && (request.auth.uid in resource.data.members
            || request.auth.uid == resource.data.requesterId
            || request.auth.uid == resource.data.receiverId
            || isAdmin());
    }

    // ===== GROUPS =====
    match /groups/{groupId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();

      // ── Update rules ──────────────────────────────────────────────
      // The group doc has many fields and several legitimate writers
      // (current admins, joining users, leaving users, members
      // setting a meetup destination). We split the matrix into two
      // lanes:
      //
      //   1. **Admin lane** — any current admin can update arbitrary
      //      fields (name, avatar, description, conversationId,
      //      memberCount, etc.).
      //
      //   2. **Self-membership lane** — a non-admin user is only
      //      allowed to mutate their own membership: arrayUnion(self)
      //      onto memberIds (join via invite code) or arrayRemove(self)
      //      (leave). They may also bump memberCount by ±1 to keep
      //      the denormalized counter consistent. No other field may
      //      be touched.
      //
      //   3. **Meetup lane** — meetupDestination writes are gated to
      //      current group members (existing rule).
      //
      // The bug we fixed: previously this allowed ANY authenticated
      // user to update the group (and write any role into a member
      // doc), so a malicious client could promote themselves to admin
      // or rewrite anyone else's membership. Now only admins or the
      // user mutating their own membership can change anything.
      allow update: if isAuthenticated() && (
        // (1) Admin can do anything.
        isCurrentAdmin(groupId)
        // (2) Self-join: only memberIds (arrayUnion self) and optionally
        //     memberCount may change. The user must end up in memberIds.
        || isSelfJoinUpdate(groupId)
        // (3) Self-leave: only memberIds (arrayRemove self) and optionally
        //     memberCount may change. The user must NO LONGER be in memberIds.
        || isSelfLeaveUpdate(groupId)
        // (4) Meetup pin update — already member-gated below.
        || (
          onlyAffects(['meetupDestination'])
          && (request.auth.uid in resource.data.memberIds)
        )
      );

      allow delete: if isAuthenticated() && request.auth.uid == resource.data.createdBy;

      // ── Members subcollection ─────────────────────────────────────
      // Two writers per doc:
      //   • Self — the user can create their own entry (joining), delete
      //     it (leaving), or update only `isMuted`-style settings on
      //     their own row. They CAN'T self-promote: setting role=ADMIN
      //     is rejected unless the request is from a current admin.
      //   • Admin — any current admin can write any member's row.
      match /members/{memberId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;

        // Create: must be the user themselves OR an admin. Self-creators
        // cannot bootstrap themselves as ADMIN unless they're the group
        // creator (covered by isCurrentAdmin via createGroup's batched
        // admin doc — the admin doc lands in the same transaction).
        allow create: if isAuthenticated() && (
          // (a) Admin creates anyone's member doc.
          isCurrentAdmin(groupId)
          // (b) Self-create as a regular MEMBER (joining via invite code).
          || (isSelf(memberId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.role == 'MEMBER')
          // (c) Self-create as ADMIN — only when this user is the group
          //     creator (group's createdBy field). Mirrors createGroup,
          //     where the admin doc and the group doc are written in the
          //     same batch. We use `getAfter` to read the group doc as
          //     it will look AFTER the batch commits, so the just-created
          //     group's createdBy is visible from inside the rule.
          || (isSelf(memberId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.role == 'ADMIN'
              && request.auth.uid == getAfter(/databases/$(database)/documents/groups/$(groupId)).data.createdBy)
        );

        // Update: admin can change anything. Self can only update
        // non-role fields (e.g. their own mute setting). Self CANNOT
        // self-promote.
        allow update: if isAuthenticated() && (
          isCurrentAdmin(groupId)
          || (isSelf(memberId)
              && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        );

        // Delete: admin removes someone OR self leaves.
        allow delete: if isAuthenticated() && (
          isCurrentAdmin(groupId)
          || isSelf(memberId)
        );
      }

      match /locations/{userId} {
        // DEPRECATED: remove after migration to consolidated activeLocations collection
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
        allow write: if request.auth.uid == userId;
      }
    }

    // ===== CONVERSATIONS =====
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;

      // Create: authenticated user must be a participant in the new conversation
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds;

      // Update: participant can update client-side metadata only.
      // Server-managed fields (recentMessages, unreadCounts, lastMessage*)
      // are written via Admin SDK which bypasses rules.
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['recentMessages', 'oldestRecentTimestamp']));

      // Legacy subcollection messages (kept for backward compatibility)
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
        allow update: if isAuthenticated();
      }
    }

    // ===== MESSAGES (top-level archive) =====
    // Server writes via Admin SDK (bypasses rules).
    // Clients may read archived messages for pagination history.
    match /messages/{messageId} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participantIds;

      // Only server (Admin SDK) creates/updates messages
      allow create, update, delete: if false;
    }

    // ===== DIRECT LOCATION SHARES =====
    // DEPRECATED: remove after migration to consolidated activeLocations collection
    match /directLocationShares/{shareId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantIds;

      match /locations/{userId} {
        // DEPRECATED: remove after migration to consolidated activeLocations collection
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/directLocationShares/$(shareId)).data.participantIds;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ===== CONSOLIDATED ACTIVE LOCATIONS =====
    // Single doc per user with their current sharing session. Supports multi-target
    // sharing — `targetIds: List<String>` holds every recipient (group ids and
    // "direct:{friendId}" entries) and `visibleTo: List<String>` is the union of
    // member uids across all targets. Reads are gated by `visibleTo`, so when the
    // user adds or removes a target the recipient list updates atomically.
    match /activeLocations/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
            || request.auth.uid in resource.data.visibleTo);
      // Only the document owner can write their own session.
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
