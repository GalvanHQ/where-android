<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        App colours are defined in core/theme/Color.kt and managed entirely
        by MaterialTheme. The XML colours below are needed by surfaces
        that can't read Compose values:
          - Theme.SplashScreen
          - Legacy widgets / RemoteViews
          - Notification accents

        splash_background — matches LightColorScheme.background (Neutral98).
        splash_background_dark — matches DarkColorScheme.background (Neutral4).
    -->
    <color name="splash_background">#FFFAFAFA</color>
    <color name="splash_background_dark">#FF0D0D0D</color>

    <!-- Brand yellow (#F9DF4D) — the logo bubble. Used as the splash
         icon tint and as a fallback accent in places that can't
         reference Compose colors. Matches Primary80 / BrandYellow. -->
    <color name="brand_primary">#FFF9DF4D</color>

    <!-- Deep gold variant (Primary40) — for any surface that needs the
         brand on a *light* background where contrast matters
         (notification icons on white, monochrome legacy widgets). -->
    <color name="brand_primary_dark">#FF7E5C00</color>
</resources>
